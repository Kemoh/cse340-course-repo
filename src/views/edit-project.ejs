<%- include("partials/header") %>

<main>
    <h1><%= title %></h1>

    <form action="/edit-project/<%= projectDetails.project_id %>" method="POST">

        <!-- Project Title -->
        <div class="form-group">
            <label for="title">
                Service Project Title:
            </label>

            <input
                type="text"
                id="title"
                name="title"
                maxlength="150"
                value="<%= projectDetails.title %>"
                required>
        </div>

        <!-- Description -->
        <div class="form-group">
            <label for="description">
                Description:
            </label>

            <textarea
                id="description"
                name="description"
                maxlength="500"
                required><%= projectDetails.description %></textarea>
        </div>

        <!-- Location -->
        <div class="form-group">
            <label for="location">
                Location:
            </label>

            <input
                type="text"
                id="location"
                name="location"
                maxlength="150"
                value="<%= projectDetails.location %>"
                required>
        </div>

        <!-- Date -->
        <div class="form-group">
            <label for="date">
                Date:
            </label>

            <input
                type="date"
                id="date"
                name="date"
                value="<%= projectDetails.date.toISOString().split('T')[0] %>"
                required>
        </div>

        <!-- Organization -->
        <div class="form-group">
            <label for="organizationId">
                Organization:
            </label>

            <select id="organizationId" name="organizationId" required>
                <% organizations.forEach(organization => { %>
                    <option
                        value="<%= organization.organization_id %>"
                        <%= organization.organization_id === projectDetails.organization_id ? "selected" : "" %>>
                        <%= organization.name %>
                    </option>
                <% }) %>
            </select>
        </div>

        <!-- Update Project -->
        <button type="submit">
            Update Project
        </button>

    </form>
</main>

<%- include("partials/footer") %>