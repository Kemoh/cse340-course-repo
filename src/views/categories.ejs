<%- include("partials/header") %>
<main>
  <div class="categories">
    <h1><%= title %></h1>

    <h2>Popular Categories</h2>

    <ul>
        <% categories.forEach(category => { %>
          <li>
            <a href="/category/<%= category.category_id %>"><%= category.name %>
            </a>
          </li>
      <%  }); %>
    </ul>
  </div>

  <div>
    <!-- Link to new category form -->
    <p>
      <a href="/new-category">
        Add New Category
      </a>
    </p>
  </div>
</main>
<%- include("partials/footer") %>
