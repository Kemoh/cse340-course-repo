<%- include("partials/header") %>
<main>
    <h1><%= title%></h1>

    <form action="/edit-organization/<%= organizationDetails.organization_id %>" method="POST">

        <!-- Name -->
        <div class="form-group">
            <label for="name">
                Organization Name:
            </label>

            <input 
            type="text" 
            id="name" 
            name="name" 
            maxlength="150"
            value="<%= organizationDetails.name %>"
            required>
        </div>

        <!-- Description -->
        <div class="form-group">
            <label for="description">
                Description:
            </label>

            <textarea 
            name="description" 
            id="description" 
            maxlength="500" 
            <%= organizationDetails.description %>
            required>
            </textarea>
        </div>

        <!-- Contact email -->
        <div class="form-group">
            <label for="contactEmail">
                Contact Email:
            </label>

            <input 
            type="email" 
            id="contactEmail" 
            name="contactEmail"
            maxlength="255"  
            value="<%= organizationDetails.contact_email %>"
            required >
        </div>

        <!-- Organization logo -->
         <div class="form-group">
            <label for="logoFilename">
                Logo Filename:
            </label>

            <input 
            type="text" 
            id="logoFilename" 
            name="logoFilename" 
            maxlength="255" 
            value="<%= organizationDetails.logo_filename %>"
            required >
         </div>

        <!-- Create organization -->
        <button type="submit">
            Update Organization
        </button>
    </form>
</main>
<%- include("partials/footer") %>
