<%- include("partials/header") %>
<main>
    <div class="organization">
        
        <h1><%= title %></h1>

        <h2><%= organizationDetails.name %></h2>

        <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %>">

        <p><strong>Description:</strong> <%= organizationDetails.description %></p>

        <h3>Service Projects</h3>
        <ul>
            <% projects.forEach(project => { %>
                <li><a href="/project/<%= project.project_id %>"><%= project.title %></a></li>
            <% }); %>
        </ul>
    </div>
</main>
<%- include("partials/footer") %>
